STRINGTABLE PRELOAD
BEGIN
    IDS_PACKAGE_NAME, "Версия Windows#"
END

IDD_VERSION_DLG DIALOG DISCARDABLE 20, 20, 220, 60
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
