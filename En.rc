#include <windows.h>
#include <winver.h>

STRINGTABLE PRELOAD
BEGIN
    IDS_PACKAGE_NAME, "osFree Janus Version#"
END

IDD_VERSION_DLG DIALOG DISCARDABLE 20, 20, 200, 60
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "osFree Janus Version"
FONT 8, "MS Sans Serif"
BEGIN
    LTEXT           "", IDC_VERSION_TEXT, 10, 10, 180, 20
    DEFPUSHBUTTON   "OK", IDOK, 75, 40, 50, 14
END
